```{r}
library(ggplot2)
library(caret)
library(MASS)
library(pscl)
library(rpart)
library(pROC)
```
```{r}
library(readr)
bank <- read_csv("bank-1.csv")
bank
```

Data Preprocessing
```{r}
bank$pdays_recode <- ifelse(bank$pdays == -1,0,bank$pdays)

bank$job <- as.factor(bank$job)
bank$educatin <- as.factor(bank$education)

boxplot(bank$balance, main = "Balance")
boxplot(bank$duration, main = "Call Duration")
```

Summary Statistics
```{r}
summary(bank[, sapply(bank, is.numeric)])

table(bank$job)
prop.table(table(bank$eduction))

unique(bank$pdays)
summary(bank$duration)
```

